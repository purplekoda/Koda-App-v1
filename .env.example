# ========================================
# Koda Environment Variables
# Copy this to .env.local and fill in values
# NEVER commit .env.local to version control
# ========================================

# Supabase (from Settings → API in your Supabase dashboard)
# NEXT_PUBLIC_ vars are safe to expose to the browser (anon key is RLS-protected)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# WARNING: Service role key bypasses RLS — NEVER use in client-side code.
# Only use in secure server contexts (migrations, admin scripts).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# App URL — must match your deployment domain for CORS validation
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Store deep-links (server only — never exposed to client)
TARGET_DEEP_LINK_BASE=https://www.target.com/co-cart
INSTACART_DEEP_LINK_BASE=https://www.instacart.com/store
